<%- include("partials/header.ejs") %>

<style>

    /* Hero Section */
    .heroSection {
        color: #f5f5f5;
        display: grid;
        grid-template-columns: 500px 350px;
        grid-template-rows: auto auto 50px;
        margin-top: 45px;
        margin-left: 230px;
        margin-right: 150px;

    }

    h1{
        margin: 0;
    }

    h2{
        grid-column: 1;
        grid-row: 2;
        margin: 0;
    }

    #heroImage {
        grid-column: 2;
        grid-row: span 3;
        width: 300px; 
        height: auto; 
        border-radius: 10px; 
        margin: 20px;
    }

    #heroSectionBtn {
        grid-column: 1;
        grid-row: 3;
        display: flex;
        gap: 20px;
    }

    #exploreBtn, #watchBtn {
        padding: 10px 20px;
        font-size: 16px;
        cursor: pointer;
        border: none;
        border-radius: 5px;
        color: white;
    }

    #watchBtn {
        background-color: rgba(253, 165, 0, 0.994);
    }

    #exploreBtn {
        background-color: #0000cd;
    }

    /* Container Recommended Anime*/
    .recommendSection {
        color: #ffffff;
        margin-top: 80px;
        margin-bottom: 80px;
    }

    .recommendSection h2 {
        margin-left: 20px;
        margin-bottom: 40px;
    }

    .container {
        display: grid;
        grid-template-columns: 225px 225px 225px 225px 225px;
        grid-template-rows: auto auto auto auto auto;
        gap: 20px;
        margin-top: 20px;
        margin-left: auto;
        margin-right: auto;
        width: fit-content;
        justify-items: center;
    }

    .card {
        background: #1a1a1a;
        border-radius: 12px;
        overflow: hidden;
        transition: transform 0.3s, box-shadow 0.3s;
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 12px #ffffff;
    }

    .card h4 {
        justify-content: center;
        text-decoration: none;
        display: block;
        color: white;
    }

    /* List Anime Schedule */

    /* Navigation Bar */
    .day-filters {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
    }

    .btn-day {
    padding: 8px 16px;
    border: 1px solid #ffffff;
    text-decoration: none;
    color: #ffffff;
    border-radius: 20px;
    transition: 0.3s;
    }

    .btn-day.active, .btn-day:hover {
    background-color: #ffffff;
    color: #000;
    }

    /* Grid Anime */
    .anime-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
    padding: 20px;
    }

    .anime-card {
        background: #1a1a1a;
        border-radius: 12px;
        overflow: hidden;
        transition: transform 0.3s, box-shadow 0.3s;
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
    }

    .anime-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 12px #ffffff;
    }

    .anime-card a{
        text-decoration: none;
        display: block;
        color: white;
    }

    .anime-card img {
        width: 100%;
        height: 250px;
        object-fit: cover;
        transition: opacity 0.3s ease-in;
    }

    .genreListSection h2 {
        padding: 15px;
        margin: 0;
        font-size: 1rem;
        text-align: center;
        color: #ffffff;
    }

    .info { padding: 10px; }
    .info h3 { font-size: 1rem; margin: 0; color: #6a7e93; }
</style>

    <%# Hero Section %>
<section class="heroSection">
    <h1>Welcome to FreeWanime</h1>
    <h2>Your ultimate destination for anime streaming</h2>
    <navbar id="heroSectionBtn">
        <a href="/explore"><button id="exploreBtn">Explore Now</button></a>
        <a href="/category" style="text-decoration: none;"><button id="watchBtn">Start Watching</button></a>
    </navbar>
    <img id="heroImage" src="<%= randomAnime.images.jpg.large_image_url %>" alt="<%= randomAnime.title %>">
</section>

    <%# Recommended Anime Section %>
<section class="recommendSection">
    <h2>Recommended Anime</h2>
    <div class="container">
        <% let count=0; %>
            <% recommendations.forEach(item=> { %>
                <% item.entry.forEach(anime=> { %>
                    <% if(count < 5) { %>
                        <div class="card">
                            <img src="<%= anime.images.jpg.image_url %>" alt="<%= anime.title %>">
                            <a href="<%= anime.url %>/episode">
                                <h4>
                                    <%= anime.title %>
                                </h4>
                            </a>
                        </div>
                        <% count++; %>
                            <% } %>
                                <% }); %>
                                    <% }); %>
    </div>
</section>

    <%# Category List / Genre List Section %>
        <section class="genreListSection">
            <nav class="day-filters">
                <% const days=['monday', 'tuesday' , 'wednesday' , 'thursday' , 'friday' , 'saturday' , 'sunday' ]; %>
                    <% days.forEach(d=> { %>
                        <a href="/?filter=<%= d %>" class="btn-day <%= currentDay === d ? 'active' : '' %>">
                            <%= d.charAt(0).toUpperCase() + d.slice(1) %>
                        </a>
                        <% }); %>
            </nav>
    
            <hr>
    
            <h2>Jadwal Rilis: <%= currentDay.toUpperCase() %>
            </h2>
            <div class="anime-grid">
                <% if (animeList.length> 0) { %>
                    <% animeList.forEach(anime=> { %>
                        <div class="anime-card">
                            <img src="<%= anime.images.jpg.image_url %>" alt="<%= anime.title %>">
                            <div class="info">
                                <h3>
                                    <a href="<%= anime.url %>/episode"><%= anime.title %></a>
                                </h3>
                                <p>Waktu: <%= anime.broadcast?.time || 'TBA' %> WIB</p>
                            </div>
                        </div>
                        <% }); %>
                            <% } else { %>
                                <p>Tidak ada anime yang rilis di hari ini.</p>
                                <% } %>
            </div>
        </section>

</br>
<%- include("partials/footer.ejs") %>